{
  "name": "easy-rewind-backend",
  "version": "1.0.0",
  "description": "Backend API server for easy-rewind Learning Assistant",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --forceExit --detectOpenHandles",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch --forceExit",
    "lint": "npx eslint . --ignore-pattern 'node_modules/' --ignore-pattern 'tests/'",
    "lint:fix": "npx eslint . --fix --ignore-pattern 'node_modules/'",
    "format": "npx prettier --write '**/*.{js,json,css,html}' --ignore-path .gitignore",
    "format:check": "npx prettier --check '**/*.{js,json,css,html}' --ignore-path .gitignore"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.6.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "neo4j-driver": "^6.1.0",
    "nodemailer": "^6.10.0"
  },
  "devDependencies": {
    "eslint": "^10.5.0",
    "jest": "^30.4.2",
    "nodemon": "^3.0.3",
    "prettier": "^3.5.0",
    "supertest": "^7.2.2"
  }
}
